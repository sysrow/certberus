# ═══════════════════════════════════════════════════════════════════════
# Certberus - ADVANCED CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════
# Regular admins don't need to touch this — all values have sensible defaults.
# Uncomment only what you actually need to change.
# Any CB_* value can also be set via CLI for one-off automation:
#   certberus issue --set CB_LOG_DIR=/tmp/certberus-log --set CB_HOOK_TIMEOUT=20
#
# Location:  /etc/certberus/advanced.env
# ═══════════════════════════════════════════════════════════════════════

# --- Paths ------------------------------------------------------------
#CB_PREFIX="/etc/certberus"
#CB_LOG_DIR="/var/log/certberus"
#CB_BACKUP_DIR="/var/backups/certberus"
#CB_STATE_DIR="/var/lib/certberus"
#CB_HOOKS_DIR="/etc/certberus/hooks"
#CB_LOG_FILE="/var/log/certberus/certberus.log"

# --- Logging ----------------------------------------------------------
# Send to syslog (facility: daemon) in parallel with file log
#CB_SYSLOG_ENABLED=1
#CB_SYSLOG_TAG="certberus"

# Verbose (DEBUG) output
#CB_VERBOSE=0

# Terminal colors:  auto | always | never
#CB_COLOR="auto"

# --- Dry-run ----------------------------------------------------------
# Simulate without making changes
#CB_DRY_RUN=0

# --- Firewall ---------------------------------------------------------
# Automatically open 80/443 for ACME HTTP-01.
# For HARICA/CESNET EAB this is skipped by default; to force it set
# CB_HARICA_FIREWALL_AUTO_OPEN=1.
#CB_FIREWALL_AUTO_OPEN=1
#CB_HARICA_FIREWALL_AUTO_OPEN=0

# --- Snapshots / backup -----------------------------------------------
# How many days to keep snapshots in CB_BACKUP_DIR
#CB_SNAPSHOT_RETAIN_DAYS=30

# --- Apache / mod_md --------------------------------------------------
#CB_APACHE_CONF_DIR="/etc/apache2/sites-available"
#CB_APACHE_ENABLED_DIR="/etc/apache2/sites-enabled"
#CB_MOD_MD_CONF="/etc/apache2/conf-available/certberus-md.conf"
#CB_MOD_MD_LOG_DIR="/var/log/mod_md"
# Path where the MDMessageCMD adapter is installed:
#CB_MOD_MD_HOOK_SCRIPT="/opt/certberus/mod_md-adapter.sh"

# --- nginx ------------------------------------------------------------
#CB_NGINX_CONF_DIR="/etc/nginx"
#CB_NGINX_WEBROOT="/var/www/acme"

# --- Tomcat -----------------------------------------------------------
# Supports Tomcat 9+.  "auto" detects from running services.
#CB_TOMCAT_SERVICE="auto"
#CB_TOMCAT_HOME="auto"
# Strategy for port 80 (ACME requires HTTP-01 challenge on port 80):
#   iptables  - redirect 80->8080 (recommended, no Tomcat downtime)
#   authbind  - Tomcat may bind port 80 (ssl too; complex setup)
#   webroot   - Tomcat Context mapped to /var/www/acme
#   proxy     - reverse proxy (Apache/nginx) in front of Tomcat — cert there
#CB_TOMCAT_PORT80_STRATEGY="iptables"

# --- Hook system ------------------------------------------------------
# Hook timeout (s). Hooks running longer are killed.
#CB_HOOK_TIMEOUT=60

# --- issue-only (certbot-only) hooks ----------------------------------
# issue-only obtains the cert and stops; deployment + renewal are certbot's
# job via its native deploy hooks in /etc/letsencrypt/renewal-hooks/deploy/.
# Set to 1 (or pass --enable-hooks) to instead use certberus' own hook dirs
# (post-issue.d, renewed.d) plus a generated certbot bridge hook.
#CB_ENABLE_HOOKS=0
# Inline command registered as certbot's native --deploy-hook (equivalent to
# --hook "..."). Runs on issuance and every renewal. Independent of the above.
#CB_CERTBOT_DEPLOY_HOOK=""

# --- ACME -------------------------------------------------------------
# Directory URLs for individual CAs. Usually no need to change.
#CB_ACME_URL_LETSENCRYPT_PROD="https://acme-v02.api.letsencrypt.org/directory"
#CB_ACME_URL_LETSENCRYPT_STAGING="https://acme-staging-v02.api.letsencrypt.org/directory"
#CB_ACME_URL_HARICA="https://acme.harica.gr/YOUR_ALIAS/directory"
#CB_ACME_URL_ZEROSSL="https://acme.zerossl.com/v2/DV90"

# --- Retries ----------------------------------------------------------
# How many times to retry if DNS / ACME challenge fails
#CB_RETRY_COUNT=3
#CB_RETRY_DELAY=10

# --- Notifications (optional, used e.g. by hooks/post-issue.d) --------
# Webhook URL (Slack/Discord/Teams format). Empty = disabled.
#CB_NOTIFY_WEBHOOK=""
# Email for failure notifications (requires mailx or sendmail)
#CB_NOTIFY_EMAIL=""
