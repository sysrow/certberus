# ═══════════════════════════════════════════════════════════════════════
# Certberus - BASIC CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════
# This is the MINIMAL configuration that the admin must fill in.
# Advanced options are in advanced.env (usually no changes needed).
#
# Location:  /etc/certberus/config.env
# ═══════════════════════════════════════════════════════════════════════

# --- REQUIRED ---------------------------------------------------------

# Contact email for CA (Let's Encrypt / HARICA send expiry notifications)
CB_EMAIL="admin@example.com"

# CA that will issue certificates:
#   letsencrypt   = Let's Encrypt (free, most common)
#   harica        = HARICA / CESNET TCS (academic, requires EAB)
#   zerossl       = ZeroSSL (free, requires EAB since 2024)
CB_CA="letsencrypt"

# Which webserver to configure (or "auto" to detect):
#   auto | apache | nginx | tomcat | jetty | caddy | issue-only
#
# issue-only = just obtain the cert into /etc/letsencrypt (like plain
#              certbot) and configure NO service. Wire any deployment
#              via hooks. (alias: certbot-only)
CB_WEBSERVER="auto"


# --- HARICA / EAB (only if CB_CA=harica or zerossl) ------------------

# Kid and HMAC obtained from https://cm.harica.gr (account -> API / EAB)
CB_EAB_KID=""
CB_EAB_HMAC=""

# ACME directory URL.
# WARNING: Leave empty if CB_CA=letsencrypt! Only set this if you have
# a custom ACME endpoint (HARICA/ZeroSSL or private CA).
# HARICA uses a per-account/per-alias directory URL, so you must fill it
# explicitly (there is no safe universal fallback).
# Example HARICA: https://acme.harica.gr/YOUR_ALIAS/directory
CB_ACME_URL=""


# --- DOMAINS ----------------------------------------------------------

# Space-separated list of domains. First one is primary.
# If left empty, the script will try to detect them from webserver config.
CB_DOMAINS=""


# --- BEHAVIOR ---------------------------------------------------------

# Automatically answer YES to all interactive prompts (non-interactive).
# 0 = ask (recommended for first install), 1 = automatic
CB_ASSUME_YES=0

# Use test CA (staging) instead of production.
# Recommended for first attempt (no rate limits). 0 = production, 1 = staging
CB_STAGING=0
