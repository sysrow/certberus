#!/bin/bash
# certberus - unified orchestrator for Apache/nginx/Tomcat + LE/HARICA/ZeroSSL
#
# Installed to:      /usr/local/sbin/certberus
# Libraries:         /usr/local/lib/certberus/
# Webserver modules: /usr/local/lib/certberus/webservers/
# Configuration:     /etc/certberus/{config.env,advanced.env}
# Hooks:             /etc/certberus/hooks/<event>.d/
# Log:               /var/log/certberus/certberus.log
#
set -uo pipefail

CB_VERSION="0.1.18"

# Locate libraries - dev mode (repo) or installed mode
_SELF_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
if [[ -f "$_SELF_DIR/../lib/common.sh" ]]; then
    # Dev mode (run directly from repo: bin/certberus)
    CB_LIB_DIR="$(cd "$_SELF_DIR/../lib" && pwd)"
    CB_WEBSERVERS_DIR="$(cd "$_SELF_DIR/../webservers" && pwd)"
elif [[ -f /usr/local/lib/certberus/common.sh ]]; then
    CB_LIB_DIR="/usr/local/lib/certberus"
    CB_WEBSERVERS_DIR="/usr/local/lib/certberus/webservers"
elif [[ -f /opt/certberus/lib/common.sh ]]; then
    CB_LIB_DIR="/opt/certberus/lib"
    CB_WEBSERVERS_DIR="/opt/certberus/webservers"
else
    echo "[ERR] Cannot find certberus libraries. Run install.sh." >&2
    exit 2
fi
export CB_LIB_DIR

# shellcheck disable=SC1091
source "$CB_LIB_DIR/common.sh"
# shellcheck disable=SC1091
source "$CB_LIB_DIR/os.sh"
# shellcheck disable=SC1091
source "$CB_LIB_DIR/dns.sh"
# shellcheck disable=SC1091
source "$CB_LIB_DIR/firewall.sh"
# shellcheck disable=SC1091
source "$CB_LIB_DIR/hooks.sh"
# shellcheck disable=SC1091
source "$CB_LIB_DIR/discover.sh"
# shellcheck disable=SC1091
source "$CB_LIB_DIR/scan.sh"
cb_load_config
cb_ensure_runtime_dirs

usage() {
    cat <<EOF
certberus v$CB_VERSION - unified cert deployment

Usage: certberus [GLOBAL] COMMAND [ARGS]

  ╭───────────────────────────────────────────────────────────────╮
  │  MAIN COMMANDS                                                 │
  ╰───────────────────────────────────────────────────────────────╯

  certberus interactive    Interactive wizard (asks about everything).
                           Recommended for first-time setup.
                           Alias: install

  certberus auto           Fully automatic: auto-detect + issue/renew.
                           No prompts, suitable for cron/CI.
                           Alias: run

  ╭───────────────────────────────────────────────────────────────╮
  │  DIAGNOSTICS                                                    │
  ╰───────────────────────────────────────────────────────────────╯

  doctor        Environment diagnostics (DNS, firewall, ports, modules)
  test-domain D Preflight for a domain (DNS, CAA, port 80/443, cert)
  discover      Show domains pointing to this server

  ╭───────────────────────────────────────────────────────────────╮
  │  CERTIFICATES                                                   │
  ╰───────────────────────────────────────────────────────────────╯

  status        Overview: OS, webserver, installed modules
  expiry        Expiry table for all certificates
  cert-info [D] No argument: compact overview. With domain: details.
  scan          Deep X.509 inventory across the entire machine (FS+configs+TLS)

  ╭───────────────────────────────────────────────────────────────╮
  │  MANAGEMENT                                                     │
  ╰───────────────────────────────────────────────────────────────╯

  renew         Renew existing certs (does not issue new ones)
  revoke D      Revoke certificate for a domain
  rollback      Restore the latest snapshot (offers restart)
  snapshots     List saved snapshots
  hooks         Manage hook scripts (list / show / run)
  logs [N]      Last N lines of the log (default 50)
  version       Version
  help          This help

  ╭───────────────────────────────────────────────────────────────╮
  │  GLOBAL OPTIONS (usually not needed - use config.env)         │
  ╰───────────────────────────────────────────────────────────────╯

  --webserver apache|nginx|tomcat|jetty|caddy|certbot-only|auto  (default: auto)
  --ca letsencrypt|harica|zerossl          (default: letsencrypt)
  --domain D (repeatable)      --email E
  --eab-kid KID    --eab-hmac HMAC    --acme-url URL
  --webroot DIR    --port80 STRAT (tomcat: iptables|webroot|proxy)
  --firewall       Open ports 80/443 during 'auto' (default: do NOT open)
  --no-firewall    Force certberus to leave the firewall alone
  --skip-dns-check
  --set CB_X=Y     (repeatable, advanced override)
  -t/--staging   -y/--yes   -n/--dry-run   -v/--verbose

Examples:
  certberus interactive                   # first setup - wizard
  certberus auto                          # production per config.env
  certberus auto --staging                # test without rate limits
  certberus auto --dry-run -v             # show what it would do, no changes
  certberus doctor                        # verify environment

Configuration in /etc/certberus/config.env (reads: $CB_CONFIG_FILE)
EOF
}

# -------- Webserver detection --------
cb_detect_webserver() {
    # Prefer the one that is actually running
    local active=""
    if systemctl is-active --quiet apache2 2>/dev/null || systemctl is-active --quiet httpd 2>/dev/null; then
        active="apache"
    fi
    if systemctl is-active --quiet nginx 2>/dev/null; then
        [[ -z "$active" ]] && active="nginx" || active="$active+nginx"
    fi
    if systemctl list-units --state=active 2>/dev/null | grep -E '^\s*tomcat[0-9]*\.service'; then >/dev/null
        [[ -z "$active" ]] && active="tomcat" || active="$active+tomcat"
    fi
    if systemctl list-units --state=active 2>/dev/null | grep -E '^\s*(jetty|shibboleth-idp)[0-9]*\.service'; then >/dev/null
        [[ -z "$active" ]] && active="jetty" || active="$active+jetty"
    fi
    if systemctl is-active --quiet caddy 2>/dev/null; then
        [[ -z "$active" ]] && active="caddy" || active="$active+caddy"
    fi

    if [[ -z "$active" ]]; then
        # Fallback: what is installed but not active
        { cb_pkg_installed apache2 || cb_pkg_installed httpd; } && active="apache(stopped)"
        cb_pkg_installed nginx   && active="${active:+$active,}nginx(stopped)"
        cb_pkg_installed caddy   && active="${active:+$active,}caddy(stopped)"
    fi
    printf '%s' "$active"
}

# -------- Global flag parsing --------
CB_CA_CLI=""; CB_WEBSERVER_CLI=""
CLI_DOMAINS=""; CLI_EMAIL=""; CLI_EAB_KID=""; CLI_EAB_HMAC=""; CLI_ACME_URL=""
CLI_WEBROOT=""; CLI_PORT80=""
CLI_AUTO=0
CLI_SET_ARGS=()

CB_CMD=""
parse_global() {
    # Accepts flags and the first non-flag as the command; also parses flags after the command.
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --webserver) [[ $# -ge 2 ]] || cb_die "--webserver requires a value"; shift; CB_WEBSERVER_CLI="$1" ;;
            --ca)        [[ $# -ge 2 ]] || cb_die "--ca requires a value"; shift; CB_CA_CLI="$1" ;;
            --domain)    [[ $# -ge 2 ]] || cb_die "--domain requires a value"; shift; CLI_DOMAINS="$CLI_DOMAINS $1" ;;
            --email)     [[ $# -ge 2 ]] || cb_die "--email requires a value"; shift; CLI_EMAIL="$1" ;;
            --eab-kid)   [[ $# -ge 2 ]] || cb_die "--eab-kid requires a value"; shift; CLI_EAB_KID="$1" ;;
            --eab-hmac)  [[ $# -ge 2 ]] || cb_die "--eab-hmac requires a value"; shift; CLI_EAB_HMAC="$1" ;;
            --acme-url)  [[ $# -ge 2 ]] || cb_die "--acme-url requires a value"; shift; CLI_ACME_URL="$1" ;;
            --webroot)   [[ $# -ge 2 ]] || cb_die "--webroot requires a value"; shift; CLI_WEBROOT="$1" ;;
            --port80)    [[ $# -ge 2 ]] || cb_die "--port80 requires a value"; shift; CLI_PORT80="$1" ;;
            --no-firewall)
                cb_apply_cli_set "CB_FIREWALL_AUTO_OPEN=0"
                CLI_SET_ARGS+=("CB_FIREWALL_AUTO_OPEN=0")
                ;;
            --firewall|--open-firewall)
                cb_apply_cli_set "CB_FIREWALL_AUTO_OPEN=1"
                cb_apply_cli_set "CB_HARICA_FIREWALL_AUTO_OPEN=1"
                CLI_SET_ARGS+=("CB_FIREWALL_AUTO_OPEN=1" "CB_HARICA_FIREWALL_AUTO_OPEN=1")
                ;;
            --skip-dns-check)
                cb_apply_cli_set "CB_SKIP_DNS_CHECK=1"
                CLI_SET_ARGS+=("CB_SKIP_DNS_CHECK=1")
                ;;
            --set)
                [[ $# -ge 2 ]] || cb_die "--set requires a value CB_NAME=value"
                shift
                cb_apply_cli_set "$1"
                CLI_SET_ARGS+=("$1")
                ;;
            -t|--staging) CB_STAGING=1 ;;
            -y|--yes)     CB_ASSUME_YES=1 ;;
            -n|--dry-run) CB_DRY_RUN=1 ;;
            -v|--verbose) CB_VERBOSE=1 ;;
            --auto)  CLI_AUTO=1 ;;
            -V|--version) echo "certberus $CB_VERSION"; exit 0 ;;
            -h|--help) CB_CMD="help" ;;
            --) shift; REMAINING+=("$@"); return 0 ;;
            -*)
                # After CB_CMD is set, unknown flags are subcommand flags (cmd_scan etc.)
                if [[ -n "$CB_CMD" ]]; then
                    REMAINING+=("$1")
                else
                    cb_warn "Unknown flag: $1"
                fi
                ;;
            *)
                if [[ -z "$CB_CMD" ]]; then
                    CB_CMD="$1"
                else
                    REMAINING+=("$1")
                fi
                ;;
        esac
        shift
    done
}

# Forwards global flags to webserver scripts
build_forward_args() {
    local target_ws="${1:-}"
    local -a out=()
    [[ "${CB_STAGING:-0}" == "1" ]] && out+=(-t)
    [[ "${CB_ASSUME_YES:-0}" == "1" ]] && out+=(-y)
    [[ "${CB_DRY_RUN:-0}" == "1" ]] && out+=(-n)
    [[ "${CB_VERBOSE:-0}" == "1" ]] && out+=(-v)
    [[ -n "$CB_CA_CLI" ]] && out+=(--ca "$CB_CA_CLI")
    [[ -n "$CLI_EMAIL" ]] && out+=(--email "$CLI_EMAIL")
    [[ -n "$CLI_EAB_KID" ]] && out+=(--eab-kid "$CLI_EAB_KID")
    [[ -n "$CLI_EAB_HMAC" ]] && out+=(--eab-hmac "$CLI_EAB_HMAC")
    [[ -n "$CLI_ACME_URL" ]] && out+=(--acme-url "$CLI_ACME_URL")
    if [[ -n "$CLI_WEBROOT" ]]; then
        case "$target_ws" in
            nginx|tomcat|jetty|certbot-only) out+=(--webroot "$CLI_WEBROOT") ;;
            apache) cb_warn "--webroot has no effect for Apache mod_md (mod_md manages the challenge itself)." ;;
            caddy) cb_warn "--webroot has no effect for Caddy (Caddy manages the challenge itself)." ;;
        esac
    fi
    [[ -n "$CLI_PORT80" && "$target_ws" == "tomcat" ]] && out+=(--port80 "$CLI_PORT80")
    local kv
    for kv in "${CLI_SET_ARGS[@]}"; do out+=(--set "$kv"); done
    # If the user explicitly passed --domain, use ONLY CLI domains
    # and reset CB_DOMAINS from config.env (otherwise old domains get appended to new ones).
    local d
    declare -A _seen=()
    if [[ -n "${CLI_DOMAINS// /}" ]]; then
        out+=(--set "CB_DOMAINS=")
    fi
    for d in $CLI_DOMAINS; do
        [[ -z "$d" ]] && continue
        [[ -n "${_seen[$d]:-}" ]] && continue
        _seen[$d]=1
        out+=(--domain "$d")
    done
    printf '%s\n' "${out[@]}"
}

# -------- Auto discovery: populates CLI_DOMAINS if empty --------
# Usage: before cmd_issue_webserver(). If CLI_AUTO=1 and CLI_DOMAINS empty,
# loads domains via cb_discover_all, filters, optionally confirms interactively.
# With --auto --force: no output, fails hard if email or domains are missing.
auto_discover_or_die() {
    [[ "$CLI_AUTO" != "1" ]] && return 0

    local ws="${CB_WEBSERVER_CLI:-auto}"
    cb_banner "Auto-discovery of domains"
    cb_log "Webserver: $ws"

    local -a discovered=()
    mapfile -t discovered < <(cb_discover_all "$ws")
    cb_discover_load_stats

    cb_log "Sources:  certbot=${CB_DISC_FROM_CERTBOT:-0}  mod_md=${CB_DISC_FROM_MOD_MD:-0}  webserver=${CB_DISC_FROM_WEBSERVER:-0}  https=${CB_DISC_FROM_HTTPS:-0}"
    if [[ -n "${CB_DISC_SKIPPED_NO_RESOLVE:-}" ]]; then
        cb_warn "Skipped (not pointing here): $CB_DISC_SKIPPED_NO_RESOLVE"
    fi

    if (( ${#discovered[@]} == 0 )); then
        local _ip; _ip="$(cb_server_ipv4 2>/dev/null || echo '?')"
        local _host; _host="$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo 'mydomain.example')"
        cb_error "No domain found pointing to this server."
        cb_log "Verify:"
        cb_log "  - DNS A/AAAA records for your domains point to $_ip"
        cb_log "  - Webserver (apache/nginx) has a VirtualHost with ServerName configured"
        cb_log ""
        cb_log "Or specify a domain manually:"
        cb_log "  certberus auto --email <your@email> --domain $_host"
        cb_log "  certberus auto --email <your@email> --domain a.example --domain b.example"
        cb_log ""
        cb_log "Tip: 'certberus interactive' walks you through the setup (creates config.env)."
        exit 2
    fi

    cb_ok "Found ${#discovered[@]} domains pointing to this server:"
    local d
    for d in "${discovered[@]}"; do cb_log "  - $d"; done

    if [[ "$CB_ASSUME_YES" == "1" ]]; then
        cb_log "(-y: no confirmation needed)"
    else
        if ! cb_ask_yn "Continue with these domains?" "Y/n"; then
            cb_log "Cancelled by user."
            exit 0
        fi
    fi

    CLI_DOMAINS="${discovered[*]}"
}

# -------- Command: discover --------
cmd_discover() {
    local ws="${CB_WEBSERVER_CLI:-auto}"
    cb_banner "Certberus - discover ($ws)"
    local -a discovered=()
    mapfile -t discovered < <(cb_discover_all "$ws")
    cb_discover_load_stats
    cb_log "Sources:  certbot=${CB_DISC_FROM_CERTBOT:-0}  mod_md=${CB_DISC_FROM_MOD_MD:-0}  webserver=${CB_DISC_FROM_WEBSERVER:-0}  https=${CB_DISC_FROM_HTTPS:-0}"
    cb_sep
    if (( ${#discovered[@]} == 0 )); then
        cb_warn "No domain has DNS A/AAAA pointing to this server."
        cb_log "  Tips:"
        cb_log "    - check 'apachectl -S' / 'nginx -T' (are ServerName entries present?)"
        cb_log "    - check mod_md store: /etc/apache2/md/ or /etc/httpd/md/"
        cb_log "    - DNS record must A/AAAA point to this machine (test: certberus test-domain DOMAIN)"
    else
        cb_ok "Candidates for certificate issuance:"
        local d
        for d in "${discovered[@]}"; do echo "  $d"; done
    fi
    if [[ -n "${CB_DISC_SKIPPED_NO_RESOLVE:-}" ]]; then
        cb_sep
        cb_warn "Found, but NOT pointing here (DNS points elsewhere / wildcard / unresolvable):"
        echo "$CB_DISC_SKIPPED_NO_RESOLVE" | tr ',' '\n' | sed 's/^/  /'
    fi
}

# -------- Command: test-domain DOMAIN --------
cmd_test_domain() {
    local d="${REMAINING[1]:-}"
    [[ -z "$d" ]] && cb_die "Usage: certberus test-domain <domain>"
    cb_validate_domain "$d" || cb_die "Invalid domain format: $d"

    cb_banner "Test: $d"
    local myip myip6
    myip=$(cb_server_ipv4 2>/dev/null)
    myip6=$(cb_server_ipv6 2>/dev/null)
    cb_log "My server IPv4: ${myip:-?}"
    cb_log "My server IPv6: ${myip6:-?}"
    cb_sep

    local a6 aaaa
    a6=$(cb_resolve_a "$d" | tr -s ' ')
    aaaa=$(cb_resolve_aaaa "$d" | tr -s ' ')
    cb_log "DNS A:     ${a6:-<none>}"
    cb_log "DNS AAAA:  ${aaaa:-<none>}"

    local match=0 port80_ok=1
    if cb_domain_points_here "$d"; then
        cb_ok "Domain points to this server."
        match=1
    else
        cb_error "Domain does NOT point to this server."
    fi
    cb_sep

    cb_log "CAA record (issue):"
    if command -v dig >/dev/null 2>&1; then
        local caa; caa=$(dig +short CAA "$d" 2>/dev/null)
        if [[ -z "$caa" ]]; then
            cb_log "  <none — all CAs allowed>"
        else
            echo "$caa" | sed 's/^/  /'
        fi
    else
        cb_warn "dig is not installed"
    fi
    cb_sep

    # Port 80 reachability test
    if [[ "$match" == "1" && -n "$myip" ]]; then
        cb_log "Testing reachability of http://$d/ (port 80)..."
        if timeout 5 bash -c '
            exec 3<>/dev/tcp/'"$d"'/80 || exit 1
            printf "HEAD / HTTP/1.0\r\nHost: %s\r\n\r\n" "'"$d"'" >&3
            head -1 <&3
            exec 3>&-
        ' 2>/dev/null | grep 'HTTP'; then >/dev/null
            cb_ok "Port 80: reachable (ACME HTTP-01 should work)"
        else
            cb_warn "Port 80: unreachable from outside — ACME HTTP-01 will fail"
            port80_ok=0
        fi
    fi
    cb_sep

    # Existing certbot cert?
    if command -v certbot >/dev/null 2>&1; then
        if certbot certificates 2>/dev/null | awk '/Domains:/ {for(i=2;i<=NF;i++) print $i}' | grep -qFx "$d"; then
            cb_log "Existing certbot cert: YES"
            certbot certificates --domain "$d" 2>/dev/null | grep -E 'Certificate|Expiry|Domains|Path' | sed 's/^/  /'
        fi
    fi

    # Live HTTPS
    if command -v openssl >/dev/null 2>&1; then
        cb_sep
        cb_log "Live HTTPS cert (port 443):"
        local cert
        cert=$(echo | timeout 4 openssl s_client -servername "$d" -connect "$d:443" 2>/dev/null \
            | openssl x509 -noout -subject -issuer -dates 2>/dev/null)
        if [[ -n "$cert" ]]; then
            echo "$cert" | sed 's/^/  /'
        else
            cb_warn "  HTTPS unavailable / no certificate served"
        fi
    fi

    if [[ "$match" != "1" ]]; then
        return 1
    elif [[ "$port80_ok" != "1" ]]; then
        return 2
    fi
    return 0
}

# -------- Command: expiry --------
cmd_expiry() {
    cb_banner "Certberus — certificate expiry"
    local any=0
    # Certbot certy
    if command -v certbot >/dev/null 2>&1; then
        local certs_dir=/etc/letsencrypt/live
        if [[ -d "$certs_dir" ]]; then
            cb_log "certbot (Let's Encrypt / other ACME):"
            any=1
            local d
            for d in "$certs_dir"/*/; do
                [[ -d "$d" ]] || continue
                local name cert
                name=$(basename "$d")
                cert="$d/cert.pem"
                [[ -f "$cert" ]] || continue
                _print_cert_expiry "$name" "$cert"
            done
        fi
    fi
    # mod_md
    local md_store; md_store="$(_cb_find_md_store 2>/dev/null || true)"
    if [[ -n "$md_store" ]]; then
        cb_sep
        cb_log "mod_md ($md_store):"
        any=1
        local d
        for d in "$md_store"/*/; do
            [[ -d "$d" ]] || continue
            local name; name=$(basename "$d")
            local cert="$d/pubcert.pem"
            [[ ! -f "$cert" ]] && cert="$d/fullchain.pem"
            [[ -f "$cert" ]] || continue
            _print_cert_expiry "$name" "$cert"
        done
    fi
    if (( any == 0 )); then
        cb_warn "No certificates found."
    fi
}

_print_cert_expiry() {
    local name="$1" cert="$2"
    command -v openssl >/dev/null 2>&1 || return 0
    local end_s now_s days
    local end; end=$(timeout 5 openssl x509 -enddate -noout -in "$cert" </dev/null 2>/dev/null | sed 's/^notAfter=//')
    [[ -z "$end" ]] && return 0
    end_s=$(date -d "$end" +%s 2>/dev/null) || return 0
    now_s=$(date +%s)
    days=$(( (end_s - now_s) / 86400 ))
    local color="$CB_C_GRN" mark="OK"
    if (( days < 0 )); then color="$CB_C_RED"; mark="EXPIRED"
    elif (( days < 7 )); then color="$CB_C_RED"; mark="CRITICAL"
    elif (( days < 30 )); then color="$CB_C_YLW"; mark="WARN"
    fi
    printf '  %s%-40s %4d days [%s]%s\n' "$color" "$name" "$days" "$mark" "$CB_C_RST"
}

# -------- Command: revoke DOMAIN --------
cmd_revoke() {
    local d="${REMAINING[1]:-}"
    [[ -z "$d" ]] && cb_die "Usage: certberus revoke <domain>"
    cb_banner "Revoke: $d"
    # Certbot cesta
    local certbot_path="/etc/letsencrypt/live/$d/cert.pem"
    if [[ -f "$certbot_path" ]] && command -v certbot >/dev/null 2>&1; then
        cb_warn "This will revoke the certificate for $d and permanently delete it."
        cb_ask_yn "Continue?" "N/y" || { cb_log "Cancelled"; exit 0; }
        if [[ "$CB_DRY_RUN" == "0" ]]; then
            certbot revoke --cert-path "$certbot_path" --delete-after-revoke --non-interactive || cb_die "Revoke failed"
            cb_ok "Revoked."
        else
            cb_log "(dry-run) certbot revoke --cert-path $certbot_path ..."
        fi
        return 0
    fi
    # mod_md: no revoke API, just remove domain (won't regenerate on next reload)
    local _md_root=""
    for _mdr in /etc/apache2/md /etc/httpd/md; do
        [[ -d "$_mdr/domains/$d" ]] && { _md_root="$_mdr"; break; }
    done
    if [[ -n "$_md_root" ]]; then
        cb_warn "mod_md has no API for ACME revocation. Can only remove the domain from mod_md records."
        cb_log "For actual revocation, use another ACME client with the same account key."
        cb_ask_yn "Remove $d from mod_md?" "N/y" || exit 0
        if [[ "$CB_DRY_RUN" == "0" ]]; then
            rm -rf "$_md_root/domains/$d" "$_md_root/staging/$d"
            cb_ok "Removed. Don't forget to update certberus-md.conf"
        fi
        return 0
    fi
    cb_die "No managed certificate found for $d (neither certbot nor mod_md)."
}

# -------- Commands --------
cmd_install() {
    cb_banner "Certberus — interactive setup"
    local ws="$CB_WEBSERVER_CLI"
    if [[ -z "$ws" || "$ws" == "auto" ]]; then
        local detected; detected=$(cb_detect_webserver)
        cb_log "Detected webserver(s): ${detected:-none}"
        if cb_has_tty && [[ "$CB_ASSUME_YES" != "1" ]]; then
            echo
            echo "Which webserver do you want to set up?"
            echo "  1) Apache  (mod_md — native ACME)"
            echo "  2) nginx   (certbot webroot)"
            echo "  3) Tomcat  (certbot + PEM connector, 9+)"
            echo "  4) Jetty   (certbot + PKCS12 keystore)"
            echo "  5) Caddy   (native ACME — zero-config TLS)"
            echo "  6) certbot-only  (HAProxy, Postfix, ...)"
            echo "  7) Exit"
            local choice
            read -r -p "Choice [1]: " choice </dev/tty
            choice="${choice:-1}"
            case "$choice" in
                1) ws="apache" ;;
                2) ws="nginx" ;;
                3) ws="tomcat" ;;
                4) ws="jetty" ;;
                5) ws="caddy" ;;
                6) ws="certbot-only" ;;
                *) exit 0 ;;
            esac
        else
            case "$detected" in
                *apache*) ws="apache" ;;
                *nginx*)  ws="nginx" ;;
                *tomcat*) ws="tomcat" ;;
                *jetty*)  ws="jetty" ;;
                *caddy*)  ws="caddy" ;;
                *) cb_die "No active webserver detected. Specify --webserver." ;;
            esac
            cb_log "Selected: $ws"
        fi
    fi

    # CA selection (if not already specified via --ca)
    if [[ -z "$CB_CA_CLI" ]] && cb_has_tty && [[ "$CB_ASSUME_YES" != "1" ]]; then
        echo
        echo "Certificate Authority:"
        echo "  1) Let's Encrypt      (free, standard choice)"
        echo "  2) HARICA / CESNET TCS (requires EAB account from cm.harica.gr)"
        echo "  3) ZeroSSL             (requires EAB account from zerossl.com)"
        local ca_choice
        read -r -p "Choice [1]: " ca_choice </dev/tty
        case "${ca_choice:-1}" in
            1) CB_CA_CLI="letsencrypt" ;;
            2) CB_CA_CLI="harica" ;;
            3) CB_CA_CLI="zerossl" ;;
            *) CB_CA_CLI="letsencrypt" ;;
        esac

        if [[ "$CB_CA_CLI" == "harica" || "$CB_CA_CLI" == "zerossl" ]]; then
            echo
            cb_log "CA '$CB_CA_CLI' requires EAB (External Account Binding)."
            if [[ -z "$CLI_EAB_KID" ]]; then
                read -r -p "EAB Key ID: " CLI_EAB_KID </dev/tty
                [[ -z "$CLI_EAB_KID" ]] && cb_die "EAB Key ID is required for $CB_CA_CLI"
            fi
            if [[ -z "$CLI_EAB_HMAC" ]]; then
                CLI_EAB_HMAC=$(cb_ask_secret "EAB HMAC Key")
                [[ -z "$CLI_EAB_HMAC" ]] && cb_die "EAB HMAC is required for $CB_CA_CLI"
            fi
            if [[ "$CB_CA_CLI" == "harica" && -z "$CLI_ACME_URL" ]]; then
                read -r -p "ACME directory URL (e.g. https://acme.harica.gr/<ALIAS>/directory): " CLI_ACME_URL </dev/tty
                [[ -z "$CLI_ACME_URL" ]] && cb_die "ACME URL is required for HARICA"
            fi
        fi
    fi

    # Offer to save config.env (only as root, otherwise no point asking)
    if [[ "$(id -u 2>/dev/null)" == "0" ]] && cb_has_tty && [[ "$CB_ASSUME_YES" != "1" && ! -f "$CB_CONFIG_FILE" ]]; then
        echo
        if cb_ask_yn "Save settings to $CB_CONFIG_FILE for future automatic renewals (certberus auto)?" "Y/n"; then
            local _email="${CLI_EMAIL:-}"
            if [[ -z "$_email" ]]; then
                read -r -p "Contact email for CA: " _email </dev/tty
                [[ -n "$_email" ]] && CLI_EMAIL="$_email"
            fi
            if cb_persist_config_skeleton "${CLI_EMAIL:-}" "" "${CB_CA_CLI:-letsencrypt}" \
                "${CLI_EAB_KID:-}" "${CLI_EAB_HMAC:-}" "${CLI_ACME_URL:-}"; then
                cb_ok "Saved to $CB_CONFIG_FILE"
            fi
        fi
    fi

    cmd_issue_webserver "$ws"
}

cmd_issue() {
    local ws="$CB_WEBSERVER_CLI"
    [[ -z "$ws" || "$ws" == "auto" ]] && ws="${CB_WEBSERVER:-auto}"
    if [[ "$ws" == "auto" ]]; then
        local d; d=$(cb_detect_webserver)
        if [[ "$d" == *+* ]]; then
            cb_die "Multiple webservers detected ($d). Choose one: --webserver apache|nginx|tomcat|jetty|caddy (or CB_WEBSERVER in config.env)."
        fi
        case "$d" in
            *apache*) ws="apache" ;;
            *nginx*)  ws="nginx" ;;
            *tomcat*) ws="tomcat" ;;
            *jetty*)  ws="jetty" ;;
            *caddy*)  ws="caddy" ;;
            *) cb_die "Cannot detect webserver. Use --webserver." ;;
        esac
        CB_WEBSERVER_CLI="$ws"
    fi
    auto_discover_or_die
    cmd_issue_webserver "$ws"
}

# -------- Command: auto --------
# Fully non-interactive mode. Takes everything from /etc/certberus/config.env,
# supplements with CLI flags and auto-detection. Fails fast on missing required fields.
#
# Idempotent:
#   - existing cert with >30 days until expiry -> just reload
#   - otherwise ACME issue/renew
#
# Suitable for cron, systemd timer, CI:
#   0 3 * * *  /usr/local/sbin/certberus auto >>/var/log/certberus/cron.log 2>&1
cmd_auto() {
    CB_ASSUME_YES=1
    if [[ -z "$CLI_DOMAINS" && -z "${CB_DOMAINS:-}" ]]; then
        CLI_AUTO=1
    fi

    # Email is required — from CLI or config (placeholder admin@example.com is a fail)
    local email="${CLI_EMAIL:-${CB_EMAIL:-}}"
    if [[ -z "$email" || "$email" == "admin@example.com" ]]; then
        cb_error "Missing valid email for CA."
        if [[ -f "$CB_CONFIG_FILE" ]]; then
            cb_log "  Set CB_EMAIL in $CB_CONFIG_FILE or use --email."
        else
            cb_log "  ($CB_CONFIG_FILE does not exist — probably running from .bundle.)"
            cb_log "  Use --email, for example:"
            cb_log "    certberus auto --email admin@example.com --domain $(hostname -f 2>/dev/null || hostname 2>/dev/null || echo example.com)"
            cb_log "  Or create $CB_CONFIG_FILE (see 'certberus interactive')."
        fi
        exit 2
    fi

    # CA-specific checks
    local ca="${CB_CA_CLI:-${CB_CA:-letsencrypt}}"
    case "$ca" in
        harica)
            local kid="${CLI_EAB_KID:-${CB_EAB_KID:-}}"
            local hmac="${CLI_EAB_HMAC:-${CB_EAB_HMAC:-}}"
            local url="${CLI_ACME_URL:-${CB_ACME_URL:-${CB_ACME_URL_HARICA:-}}}"
            [[ -n "$kid" && -n "$hmac" ]] || {
                cb_error "CA harica requires CB_EAB_KID and CB_EAB_HMAC in config.env (or --eab-kid/--eab-hmac).";
                exit 2; }
            [[ -n "$url" ]] || {
                cb_error "CA harica requires CB_ACME_URL (per-account/alias directory URL).";
                cb_log "  Example: https://acme.harica.gr/<ALIAS>/directory"
                exit 2; }
            ;;
        zerossl)
            local kid="${CLI_EAB_KID:-${CB_EAB_KID:-}}"
            local hmac="${CLI_EAB_HMAC:-${CB_EAB_HMAC:-}}"
            [[ -n "$kid" && -n "$hmac" ]] || {
                cb_error "CA zerossl requires CB_EAB_KID and CB_EAB_HMAC in config.env.";
                exit 2; }
            ;;
    esac

    # Persist skeleton config.env (if missing and we have email — typical for bundle).
    # Idempotent: never overwrites existing file.
    if [[ ! -f "$CB_CONFIG_FILE" ]]; then
        local _persist_domains="${CLI_DOMAINS:-${CB_DOMAINS:-}}"
        # trim wrapping whitespace (CLI_DOMAINS accumulates leading space via "$x $y")
        _persist_domains="${_persist_domains#"${_persist_domains%%[![:space:]]*}"}"
        _persist_domains="${_persist_domains%"${_persist_domains##*[![:space:]]}"}"
        cb_persist_config_skeleton "$email" "$_persist_domains" "$ca" \
            "${CLI_EAB_KID:-}" "${CLI_EAB_HMAC:-}" "${CLI_ACME_URL:-}" || true
    fi

    # Port-80 pre-flight: if admin didn't use --firewall, verify that
    # ACME HTTP-01 has a chance. Failure is not fatal (mod_md retries next day),
    # but we want admin to know what to do. Test is per-domain.
    if [[ "${CB_FIREWALL_AUTO_OPEN:-0}" != "1" && "${CB_SKIP_PORT80_CHECK:-0}" != "1" ]]; then
        local _doms="${CLI_DOMAINS:-${CB_DOMAINS:-}}"
        local _first_dom; _first_dom=$(echo "$_doms" | tr -s ' ' '\n' | grep -v '^$' | head -1)
        if [[ -n "$_first_dom" ]]; then
            if ! timeout 4 bash -c "exec 3<>/dev/tcp/$_first_dom/80; exec 3>&-" 2>/dev/null; then
                cb_warn "Port 80 on ${_first_dom} appears closed from outside (ACME HTTP-01 will fail)."
                cb_log "  Solutions:"
                cb_log "    A) temporarily open FW during issuance:"
                cb_log "         certberus auto --firewall --email $email${_first_dom:+ --domain $_first_dom}"
                cb_log "    B) open manually in existing policy (iptables/ufw/firewalld) then:"
                cb_log "         certberus auto"
                cb_log "    C) skip this check (proceed anyway):"
                cb_log "         CB_SKIP_PORT80_CHECK=1 certberus auto"
                cb_log ""
                cb_log "  (CA needs GET on http://${_first_dom}/.well-known/acme-challenge/<token>)"
                exit 2
            fi
        fi
    fi

    cmd_issue "$@"
}

cmd_issue_webserver() {
    local ws="$1"
    local script=""
    local ca="${CB_CA_CLI:-${CB_CA:-letsencrypt}}"
    case "$ws" in
        apache)
            if [[ "$ca" == "harica" || "$ca" == "zerossl" ]]; then
                script="$CB_WEBSERVERS_DIR/apache-md-eab.sh"
            else
                script="$CB_WEBSERVERS_DIR/apache-md.sh"
            fi
            ;;
        nginx)  script="$CB_WEBSERVERS_DIR/nginx-certbot.sh" ;;
        tomcat) script="$CB_WEBSERVERS_DIR/tomcat-certbot.sh" ;;
        jetty)  script="$CB_WEBSERVERS_DIR/jetty-certbot.sh" ;;
        caddy)  script="$CB_WEBSERVERS_DIR/caddy.sh" ;;
        certbot-only) script="$CB_WEBSERVERS_DIR/certbot-only.sh" ;;
        *) cb_die "Unknown webserver: $ws" ;;
    esac
    [[ -x "$script" ]] || cb_die "Script not found: $script"

    cb_log "Using: $script"
    local -a fwd=()
    mapfile -t fwd < <(build_forward_args "$ws")
    # Don't use `exec` — we want parent EXIT traps (e.g. bundle wrapper
    # cleaning up tmpdir with extracted libraries) to run.
    # Propagate webserver script exit code.
    "$script" "${fwd[@]}"
    exit $?
}

cmd_status() {
    cb_banner "Certberus — status"
    cb_log "OS: $CB_OS_ID $CB_OS_VERSION"
    cb_log "Firewall: $(cb_firewall_backend_pretty)"
    cb_log "Webserver(y): $(cb_detect_webserver)"

    # Installed certberus modules
    if [[ -d "$CB_STATE_DIR/installed" ]]; then
        cb_log "Installed modules:"
        for m in "$CB_STATE_DIR/installed"/*.marker; do
            [[ -f "$m" ]] || continue
            local name; name=$(basename "$m" .marker)
            local ts; ts=$(cat "$m" 2>/dev/null)
            cb_log "  - $name (since $(date -d "@$ts" '+%F %T' 2>/dev/null || echo "?"))"
        done
    fi

    # Certbot certs
    if command -v certbot >/dev/null 2>&1; then
        cb_sep
        cb_log "certbot certs:"
        certbot certificates 2>/dev/null | grep -E 'Certificate Name|Expiry Date|Domains' | sed 's/^/  /'
    fi

    # mod_md
    local _md_domains_dir=""
    for _mdp in /etc/apache2/md/domains /etc/httpd/md/domains; do
        [[ -d "$_mdp" ]] && { _md_domains_dir="$_mdp"; break; }
    done
    if [[ -n "$_md_domains_dir" ]]; then
        cb_sep
        cb_log "mod_md state:"
        command -v a2query >/dev/null && a2query -m md 2>&1 | sed 's/^/  /'
        ls -la "$_md_domains_dir/" 2>/dev/null | sed 's/^/  /'
    fi
}

# Find mod_md store directory (differs per distro/version).
_cb_find_md_store() {
    local p
    for p in /var/lib/apache2/md/md/store/domains \
             /etc/apache2/md/md/store/domains \
             /etc/apache2/md/domains \
             /var/cache/apache2/md/domains \
             /var/lib/httpd/md/md/store/domains \
             /etc/httpd/md/md/store/domains \
             /etc/httpd/md/domains \
             /var/cache/httpd/md/domains; do
        [[ -d "$p" ]] && { printf '%s' "$p"; return 0; }
    done
    local found
    found=$(find /var/lib/apache2 /etc/apache2 /var/lib/httpd /etc/httpd -maxdepth 6 -type d -name domains -path '*md*' 2>/dev/null | head -1)
    [[ -n "$found" ]] && { printf '%s' "$found"; return 0; }
    return 1
}

# certberus cert-info [DOMAIN]
# Without argument: compact table (domain | source | expiry | status).
# With domain: detailed output including md.json, certbot, live HTTPS.
cmd_cert_info() {
    local d="${REMAINING[1]:-}"

    if [[ -n "$d" ]]; then
        _cert_info_detail "$d"
    else
        _cert_info_summary
    fi
}

_cert_info_summary() {
    cb_banner "Certberus — certificate overview"
    local count=0
    printf '  %-40s %-10s %6s  %s\n' "DOMAIN" "SOURCE" "DAYS" "STATUS"
    printf '  %-40s %-10s %6s  %s\n' "$(printf '%0.s─' {1..40})" "$(printf '%0.s─' {1..10})" "$(printf '%0.s─' {1..6})" "$(printf '%0.s─' {1..8})"

    # mod_md
    local store; store="$(_cb_find_md_store 2>/dev/null || true)"
    if [[ -n "$store" ]]; then
        local entry
        for entry in "$store"/*/; do
            [[ -d "$entry" ]] || continue
            local name; name=$(basename "$entry")
            local cert="$entry/pubcert.pem"
            [[ ! -f "$cert" ]] && cert="$entry/fullchain.pem"
            if [[ -f "$cert" ]]; then
                _cert_info_table_row "$name" "mod_md" "$cert" && count=$((count+1))
            else
                printf '  %-40s %-10s %6s  %s%s%s\n' "$name" "mod_md" "-" "${CB_C_YLW}PENDING${CB_C_RST}" "" ""
                count=$((count+1))
            fi
        done
    fi

    # certbot
    local certs_dir=/etc/letsencrypt/live
    if [[ -d "$certs_dir" ]]; then
        local entry
        for entry in "$certs_dir"/*/; do
            [[ -d "$entry" ]] || continue
            local name; name=$(basename "$entry")
            local cert="$entry/cert.pem"
            [[ -f "$cert" ]] || continue
            _cert_info_table_row "$name" "certbot" "$cert" && count=$((count+1))
        done
    fi

    echo
    if (( count == 0 )); then
        cb_warn "No certificates found."
        cb_log "  Use 'certberus cert-info <domain>' for details."
    else
        cb_log "Total: $count certificate(s). For details: certberus cert-info <domain>"
    fi
}

_cert_info_table_row() {
    local name="$1" source="$2" cert="$3"
    local end days color mark
    end=$(timeout 5 openssl x509 -enddate -noout -in "$cert" </dev/null 2>/dev/null | sed 's/^notAfter=//')
    if [[ -z "$end" ]]; then
        printf '  %-40s %-10s %6s  %s\n' "$name" "$source" "?" "UNREADABLE"
        return 0
    fi
    local end_s now_s
    end_s=$(date -d "$end" +%s 2>/dev/null) || { printf '  %-40s %-10s %6s  %s\n' "$name" "$source" "?" "PARSE-ERR"; return 0; }
    now_s=$(date +%s)
    days=$(( (end_s - now_s) / 86400 ))
    color="$CB_C_GRN"; mark="OK"
    if (( days < 0 )); then color="$CB_C_RED"; mark="EXPIRED"
    elif (( days < 7 )); then color="$CB_C_RED"; mark="CRITICAL"
    elif (( days < 30 )); then color="$CB_C_YLW"; mark="WARN"
    fi
    printf '  %-40s %-10s %s%6d  [%-8s]%s\n' "$name" "$source" "$color" "$days" "$mark" "$CB_C_RST"
    return 0
}

_cert_info_detail() {
    local d="$1"
    cb_banner "Certberus - cert-info: $d"

    local store; store="$(_cb_find_md_store 2>/dev/null || true)"
    if [[ -n "$store" && -d "$store/$d" ]]; then
        cb_log "mod_md store: $store/$d"
        local cert="$store/$d/pubcert.pem"
        local mdjson="$store/$d/md.json"
        if [[ -f "$cert" ]]; then
            cb_ok "  pubcert.pem exists"
            timeout 5 openssl x509 -in "$cert" -noout -subject -issuer -dates </dev/null 2>/dev/null | sed 's/^/    /'
        else
            cb_warn "  pubcert.pem not yet present (mod_md hasn't requested it or challenge pending)"
        fi
        if [[ -f "$mdjson" ]] && command -v jq >/dev/null 2>&1; then
            cb_log "  md.json state:"
            jq -r '{state, state_descr, renew, must_staple, cert?: (.cert | keys?), domains}' \
                "$mdjson" 2>/dev/null | sed 's/^/    /' || head -20 "$mdjson" | sed 's/^/    /'
        elif [[ -f "$mdjson" ]]; then
            cb_log "  md.json (raw, install jq for pretty output):"
            head -20 "$mdjson" | sed 's/^/    /'
        fi
        cb_sep
    fi

    # certbot
    if command -v certbot >/dev/null 2>&1; then
        cb_log "certbot:"
        certbot certificates --domain "$d" 2>/dev/null | sed 's/^/  /'
        cb_sep
    fi

    # Live HTTPS test
    cb_log "Live HTTPS on ${d}:443:"
    local live_cert
    live_cert=$(echo | timeout 5 openssl s_client -servername "$d" -connect "$d:443" </dev/null 2>/dev/null)
    if [[ -n "$live_cert" ]]; then
        printf '%s\n' "$live_cert" | timeout 5 openssl x509 -noout -subject -issuer -dates -ext subjectAltName </dev/null 2>/dev/null | sed 's/^/  /' \
            || cb_warn "  Handshake not completed"
    else
        cb_warn "  Server did not establish TLS connection (cert not yet deployed?)"
    fi
    cb_sep

    # Apache error.log — relevant entries only
    local _errlog=""
    for _el in /var/log/apache2/error.log /var/log/httpd/error_log; do
        [[ -f "$_el" ]] && { _errlog="$_el"; break; }
    done
    if [[ -n "$_errlog" ]]; then
        local md_lines
        md_lines=$(grep -i "md\[.*$d" "$_errlog" 2>/dev/null | tail -5)
        if [[ -n "$md_lines" ]]; then
            cb_log "Last mod_md log entries for $d:"
            echo "$md_lines" | sed 's/^/  /'
        fi
    fi
}

# certberus scan [--format table|json|tsv] [--no-fs|--no-config|--no-listen]
# X.509 inventory on the machine — dispatch to lib/scan.sh.
cmd_scan() {
    cb_scan "$@"
    return 0
}

cmd_doctor() {
    cb_banner "Certberus — diagnostics"
    cb_log "OS: $CB_OS_ID $CB_OS_VERSION (pkg: $CB_PKG_MGR)"
    cb_log "Firewall: $(cb_firewall_backend_pretty)"
    cb_log "TTY: $(cb_has_tty && echo YES || echo NO)"
    cb_log "Server IPv4: $(cb_server_ipv4 2>/dev/null || echo '?')"
    cb_log "Server IPv6: $(cb_server_ipv6 2>/dev/null || echo '?')"
    cb_sep

    # Port 80, 443 external accessibility
    local ip; ip=$(cb_server_ipv4)
    if [[ -n "$ip" ]]; then
        cb_log "Testing port availability from the internet..."
        if timeout 5 bash -c "echo > /dev/tcp/$ip/80" 2>/dev/null; then
            cb_ok "Port 80: reachable (ACME HTTP-01)"
        else
            cb_warn "Port 80: UNREACHABLE from internet (ACME HTTP-01 will fail without an open port)"
        fi
        if timeout 5 bash -c "echo > /dev/tcp/$ip/443" 2>/dev/null; then
            cb_ok "Port 443: reachable (HTTPS)"
        else
            cb_warn "Port 443: UNREACHABLE from internet (clients cannot reach HTTPS)"
        fi
    fi

    cb_sep
    cb_log "Certberus webserver modules:"
    for f in "$CB_WEBSERVERS_DIR"/*.sh; do
        [[ -x "$f" ]] && cb_log "  [x] $(basename "$f")" || cb_warn "  [!] $(basename "$f") not executable"
    done

    cb_sep
    cb_log "Hook directories:"
    for ev in "${CB_KNOWN_EVENTS[@]}"; do
        local d="$CB_HOOKS_DIR/${ev}.d"
        if [[ -d "$d" ]]; then
            local cnt; cnt=$(find "$d" -maxdepth 1 -type f -executable 2>/dev/null | wc -l)
            (( cnt > 0 )) && cb_log "  $ev: $cnt hook(s)"
        fi
    done

    cb_sep
    cb_log "Config: $CB_CONFIG_FILE $([[ -r $CB_CONFIG_FILE ]] && echo '(OK)' || echo '(missing)')"
    cb_log "Advanced: $CB_ADVANCED_FILE $([[ -r $CB_ADVANCED_FILE ]] && echo '(OK)' || echo '(missing — using defaults)')"
}

cmd_rollback() {
    cb_banner "Certberus — rollback"
    if [[ ! -d "$CB_BACKUP_DIR" ]]; then
        cb_die "No snapshots in $CB_BACKUP_DIR"
    fi
    local last=""
    # Allow explicit snapshot path as positional arg
    if [[ -n "${REMAINING[1]:-}" && -f "${REMAINING[1]}" ]]; then
        last="${REMAINING[1]}"
    else
        # Find newest snapshot (stat -c instead of find -printf for Alpine/busybox compatibility).
        local -a _rb_files=()
        mapfile -t _rb_files < <(find "$CB_BACKUP_DIR" -maxdepth 1 -type f \( -name 'nginx-pre-*.tar.gz' -o -name 'apache2-pre-*.tar.gz' -o -name 'httpd-pre-*.tar.gz' -o -name 'tomcat-pre-*.tar.gz' -o -name 'apache-md-pre-*.tar.gz' -o -name 'certbot-only-pre-*.tar.gz' -o -name 'jetty-pre-*.tar.gz' -o -name 'caddy-pre-*.tar.gz' \) 2>/dev/null)
        local _rb_newest_ts=0 _rb_f _rb_ts
        for _rb_f in "${_rb_files[@]}"; do
            _rb_ts=$(stat -c '%Y' "$_rb_f" 2>/dev/null) || continue
            if (( _rb_ts > _rb_newest_ts )); then
                _rb_newest_ts=$_rb_ts
                last="$_rb_f"
            fi
        done
    fi
    [[ -z "$last" ]] && cb_die "No snapshots (.tar.gz)"

    # Security verification of snapshot file before extraction.
    [[ -f "$last" && -r "$last" ]] || cb_die "Snapshot not readable: $last"
    # Realpath must stay in $CB_BACKUP_DIR (unless explicit absolute path given).
    if [[ -z "${REMAINING[1]:-}" ]]; then
        local _real; _real=$(readlink -f "$last" 2>/dev/null || echo "$last")
        case "$_real" in
            "$CB_BACKUP_DIR"/*) ;;
            *) cb_die "Snapshot outside $CB_BACKUP_DIR: $_real" ;;
        esac
    fi
    # Test integrity (tar -tzf fail-fast: corrupted archive won't be extracted).
    if ! tar -tzf "$last" >/dev/null 2>&1; then
        cb_die "Snapshot is corrupted or not a gzip-tar: $last"
    fi
    cb_log "Latest snapshot: $last"
    # With -y / CB_ASSUME_YES we proceed, otherwise default N (safe).
    if [[ "$CB_ASSUME_YES" != "1" ]]; then
        cb_ask_yn "Perform rollback? (extracts to /)" "N/y" || { cb_log "Cancelled"; exit 0; }
    fi
    if [[ "$CB_DRY_RUN" == "0" ]]; then
        tar -xzf "$last" -C / && cb_ok "Extracted"
    fi
    cb_run_hooks on-rollback

    # Offer webserver restart
    local ws_detected; ws_detected=$(cb_detect_webserver)
    local restart_svc=""
    case "$ws_detected" in
        *apache*)
            if systemctl is-active --quiet httpd 2>/dev/null; then restart_svc="httpd"
            else restart_svc="apache2"; fi
            ;;
        *nginx*)  restart_svc="nginx" ;;
        *tomcat*)
            restart_svc=$(systemctl list-units --state=active 2>/dev/null | grep -oE 'tomcat[0-9]*\.service' | head -1)
            restart_svc="${restart_svc:=tomcat9}"
            ;;
        *jetty*)
            restart_svc=$(systemctl list-units --state=active 2>/dev/null | grep -oE '(jetty|shibboleth-idp)[0-9]*\.service' | head -1)
            restart_svc="${restart_svc:=jetty}"
            ;;
        *caddy*) restart_svc="caddy" ;;
    esac
    if [[ -n "$restart_svc" ]]; then
        if cb_ask_yn "Restart $restart_svc to apply changes?" "Y/n"; then
            if [[ "$CB_DRY_RUN" == "0" ]]; then
                systemctl restart "$restart_svc" 2>/dev/null && cb_ok "$restart_svc restarted" \
                    || cb_warn "Restart $restart_svc failed — check: systemctl status $restart_svc"
            else
                cb_log "[DRY-RUN] systemctl restart $restart_svc"
            fi
        else
            cb_log "Don't forget to manually: systemctl restart $restart_svc"
        fi
    fi
}

cmd_hooks() {
    local sub="${REMAINING[1]:-list}"
    case "$sub" in
        list)
            cb_banner "Hook scripts"
            for ev in "${CB_KNOWN_EVENTS[@]}"; do
                local d="$CB_HOOKS_DIR/${ev}.d"
                [[ -d "$d" ]] || continue
                local hooks; hooks=$(find "$d" -maxdepth 1 -type f \
                    ! -name '*.disabled' ! -name '*.bak' ! -name '*~' \
                    -executable 2>/dev/null | sort)
                [[ -z "$hooks" ]] && continue
                echo "== $ev =="
                echo "$hooks" | while read -r h; do
                    echo "  [x] $(basename "$h")"
                done
            done
            ;;
        show)
            local name="${REMAINING[2]:-}"
            [[ -z "$name" ]] && cb_die "Usage: certberus hooks show <filename>"
            find "$CB_HOOKS_DIR" -name "$name" -exec cat {} \;
            ;;
        run)
            local event="${REMAINING[2]:-}"
            [[ -z "$event" ]] && cb_die "Usage: certberus hooks run <event>"
            cb_run_hooks "$event"
            ;;
        *) cb_die "Unknown sub-command: $sub. Try: list|show|run" ;;
    esac
}

# -------- Command: renew --------
# Renew ONLY existing certificates. Does not issue new ones.
cmd_renew() {
    CB_ASSUME_YES=1
    cb_banner "Certberus — renew existing certificates"
    cb_require_root
    local any=0

    # certbot renew (only renews certs it already manages)
    if command -v certbot >/dev/null 2>&1; then
        local certs_dir=/etc/letsencrypt/live
        if [[ -d "$certs_dir" ]] && find "$certs_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | grep .; then >/dev/null
            any=1
            cb_log "certbot: renewing existing certificates..."
            if [[ "$CB_DRY_RUN" == "1" ]]; then
                certbot renew --dry-run 2>&1 | tail -20 | sed 's/^/  /'
            else
                certbot renew 2>&1 | tail -20 | sed 's/^/  /'
            fi
            cb_ok "certbot renew completed."
        fi
    fi

    # mod_md: graceful restart triggers internal renewal check
    local md_store; md_store="$(_cb_find_md_store 2>/dev/null || true)"
    if [[ -n "$md_store" ]] && find "$md_store" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | grep .; then >/dev/null
        any=1
        local apachectl=""
        for c in apache2ctl apachectl httpd; do
            command -v "$c" >/dev/null 2>&1 && { apachectl="$c"; break; }
        done
        if [[ -n "$apachectl" ]]; then
            cb_log "mod_md: graceful restart (mod_md checks for renewal)..."
            if [[ "$CB_DRY_RUN" == "0" ]]; then
                "$apachectl" graceful 2>/dev/null && cb_ok "Apache graceful OK" \
                    || cb_warn "Apache graceful failed"
            else
                cb_log "[DRY-RUN] $apachectl graceful"
            fi
        else
            cb_warn "Apache not available — mod_md certs cannot be renewed manually."
        fi
    fi

    if (( any == 0 )); then
        cb_warn "No existing certificates to renew."
        cb_log "  For first issuance, use 'certberus auto' or 'certberus interactive'."
    else
        cb_run_hooks post-renew
    fi
}

# -------- Command: snapshots --------
cmd_snapshots() {
    cb_banner "Certberus — snapshots"
    if [[ ! -d "$CB_BACKUP_DIR" ]]; then
        cb_warn "Directory $CB_BACKUP_DIR does not exist (no snapshots yet)."
        return 0
    fi
    local -a files=()
    mapfile -t files < <(find "$CB_BACKUP_DIR" -maxdepth 1 -type f -name '*.tar.gz' 2>/dev/null)
    if (( ${#files[@]} == 0 )); then
        cb_warn "No snapshots in $CB_BACKUP_DIR"
        return 0
    fi
    # stat -c is POSIX-compatible (works on busybox/Alpine too, unlike find -printf)
    local -a snaps=()
    local f
    for f in "${files[@]}"; do
        local mtime sz
        mtime=$(stat -c '%Y' "$f" 2>/dev/null) || continue
        sz=$(stat -c '%s' "$f" 2>/dev/null) || sz=0
        snaps+=("$mtime $sz $f")
    done
    IFS=$'\n' read -r -d '' -a snaps < <(printf '%s\n' "${snaps[@]}" | sort -rn) || true

    printf '  %-20s %10s  %s\n' "DATE" "SIZE" "FILE"
    printf '  %-20s %10s  %s\n' "$(printf '%0.s─' {1..20})" "$(printf '%0.s─' {1..10})" "$(printf '%0.s─' {1..40})"
    local line
    for line in "${snaps[@]}"; do
        [[ -z "$line" ]] && continue
        local ts_epoch sz path
        ts_epoch="${line%% *}"
        line="${line#* }"
        sz="${line%% *}"
        path="${line#* }"
        local ts_human; ts_human=$(date -d "@$ts_epoch" '+%F %T' 2>/dev/null || echo "?")
        local sz_human
        if (( sz > 1048576 )); then
            sz_human="$(( sz / 1048576 )) MB"
        elif (( sz > 1024 )); then
            sz_human="$(( sz / 1024 )) KB"
        else
            sz_human="${sz} B"
        fi
        printf '  %-20s %10s  %s\n' "$ts_human" "$sz_human" "$(basename "$path")"
    done
    echo
    cb_log "Total: ${#files[@]} snapshot(s) in $CB_BACKUP_DIR"
    cb_log "Rollback: certberus rollback  (uses latest)"
}

# -------- Command: logs [N] --------
cmd_logs() {
    local n="${REMAINING[1]:-50}"
    [[ "$n" =~ ^[0-9]+$ ]] || n=50
    if [[ ! -f "$CB_LOG_FILE" ]]; then
        cb_warn "Log file does not exist: $CB_LOG_FILE"
        cb_log "  (certberus hasn't run yet or logs are in a different location)"
        return 0
    fi
    tail -"$n" "$CB_LOG_FILE"
}

# -------- Main dispatch --------
REMAINING=()
parse_global "$@"
CMD="${CB_CMD:-help}"
# REMAINING now contains command arguments (not flags)
# For cmd_hooks we expect REMAINING to start with "hooks" - prepend for compat
REMAINING=("$CMD" "${REMAINING[@]}")

# -------- Concurrency lock --------
# For mutative commands (issue/renew/install/revoke/rollback) we hold an exclusive
# flock on /var/lock/certberus.lock. Stale locks from crashed runs are released by OS
# (flock(2) is bound to the process descriptor).
case "$CMD" in
    issue|renew|install|revoke|rollback|auto|run|interactive)
        if [[ "${CB_DRY_RUN:-0}" != "1" && "${CB_NO_LOCK:-0}" != "1" ]]; then
            CB_LOCK_FILE="${CB_LOCK_FILE:-/var/lock/certberus.lock}"
            if command -v flock >/dev/null 2>&1; then
                if ! ( umask 077; >> "$CB_LOCK_FILE" ) 2>/dev/null; then
                    CB_LOCK_FILE="/tmp/certberus-${UID:-0}.lock"
                    ( umask 077; >> "$CB_LOCK_FILE" ) 2>/dev/null || CB_LOCK_FILE=""
                fi
                if [[ -n "$CB_LOCK_FILE" ]]; then
                    # Preserve 0600 even on append (umask inside subshell doesn't propagate).
                    [[ -f "$CB_LOCK_FILE" ]] && chmod 0600 "$CB_LOCK_FILE" 2>/dev/null || true
                    exec 200>>"$CB_LOCK_FILE"
                    if ! flock -n 200; then
                        cb_die "Another certberus process is running (lock $CB_LOCK_FILE). Use CB_NO_LOCK=1 to override."
                    fi
                fi
            fi
        fi
        ;;
esac

case "$CMD" in
    interactive|install) cmd_install "$@" ;;
    auto|run)     cmd_auto "$@" ;;
    issue)       cmd_issue "$@" ;;
    renew)       cmd_renew "$@" ;;
    status)      cmd_status "$@" ;;
    doctor)      cmd_doctor "$@" ;;
    discover)    cmd_discover "$@" ;;
    test-domain|test) cmd_test_domain "$@" ;;
    cert-info|cert)   cmd_cert_info "$@" ;;
    scan|inventory)   cmd_scan "${REMAINING[@]:1}" ;;
    expiry|expires) cmd_expiry "$@" ;;
    revoke)      cmd_revoke "$@" ;;
    rollback)    cmd_rollback "$@" ;;
    snapshots)   cmd_snapshots "$@" ;;
    hooks)       cmd_hooks "$@" ;;
    logs|log)    cmd_logs "$@" ;;
    version|--version|-V) echo "certberus $CB_VERSION" ;;
    help|-h|--help|"") usage ;;
    *) echo "Unknown command: $CMD"; usage; exit 2 ;;
esac
